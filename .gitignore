# ═══════════════════════════════════════════════════════════
# HörenWeg — .gitignore
# Исключаем внутренние/рабочие файлы из репозитория
# ═══════════════════════════════════════════════════════════

# Внутренняя документация и планы (не для публики)
CLAUDE.md
PLAN-LESSONS.md

# Методологические источники (книги, не для публикации)
Источники/

# Сырые данные и временные файлы из Claude.ai
tasks/

# Исходный список уроков (внутренний файл)
list/

# Служебные скрипты валидации (внутренние инструменты)
tools/
*.tmp.js
*.backup.js

# Системные файлы OS
.DS_Store
Thumbs.db
desktop.ini

# IDE / редакторы
.vscode/
.idea/
*.swp
*.swo
*~

# Логи
*.log
npm-debug.log*

# Node (если вдруг появится)
node_modules/
package-lock.json
yarn.lock

# Python (если вдруг появится)
__pycache__/
*.pyc
.venv/
venv/
